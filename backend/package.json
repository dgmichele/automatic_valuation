{
  "name": "automatic-valuation-backend",
  "version": "1.0.0",
  "description": "Backend API per sistema di valutazione automatica immobiliare - Canavese",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --exec ts-node server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "migrate:dev": "cross-env NODE_ENV=development knex --knexfile db/knexfile.ts migrate:latest",
    "migrate:rollback:dev": "cross-env NODE_ENV=development knex --knexfile db/knexfile.ts migrate:rollback",
    "seed:dev": "cross-env NODE_ENV=development knex --knexfile db/knexfile.ts seed:run",
    "migrate:prod": "cross-env NODE_ENV=production knex --knexfile db/knexfile.ts migrate:latest",
    "seed:prod": "cross-env NODE_ENV=production knex --knexfile db/knexfile.ts seed:run",
    "test": "cross-env NODE_ENV=test jest --forceExit --detectOpenHandles",
    "test:watch": "cross-env NODE_ENV=test jest --watch"
  },
  "dependencies": {
    "@turf/boolean-point-in-polygon": "^6.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "knex": "^3.1.0",
    "node-fetch": "^2.7.0",
    "pg": "^8.11.3",
    "resend": "^3.2.0",
    "winston": "^3.13.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/node-fetch": "^2.6.11",
    "@types/pg": "^8.11.3",
    "@types/supertest": "^6.0.2",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  }
}
