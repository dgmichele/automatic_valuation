{
  "name": "automatic-valuation-backend",
  "version": "1.0.0",
  "description": "Backend API per sistema di valutazione automatica immobiliare - Canavese",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate:make": "knex migrate:make --knexfile db/knexfile.ts -x ts",
    "migrate:latest": "knex migrate:latest --knexfile db/knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile db/knexfile.ts",
    "migrate:status": "knex migrate:status --knexfile db/knexfile.ts",
    "seed:make": "knex seed:make --knexfile db/knexfile.ts -x ts",
    "seed:run": "knex seed:run --knexfile db/knexfile.ts",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "email": "email dev -d emails"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "knex": "^3.1.0",
    "node-fetch": "^2.7.0",
    "pg": "^8.16.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-email": "^6.1.5",
    "resend": "^6.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@react-email/ui": "^6.1.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/node-fetch": "^2.6.12",
    "@types/pg": "^8.16.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.9"
  }
}
